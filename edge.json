{
    "0": {
        "in": 0,
        "out": 1,
        "weight": 1,
        "cmd": "python3 getpdb.py {PDBID}"
    },
    "1": {
        "in": 1,
        "out": 2,
        "weight": 1,
        "cmd": "{GMX} pdb2gmx -f {cle_pdb} -o {pro_gro} -p {pro_top} -water {WATER_MODEL} -ff {FF}"
    },
    "2": {
        "in": 2,
        "out": 3,
        "weight": 1,
        "cmd": "{GMX} editconf -f {pro_gro} -o {box_gro} -c -d {DISTANCE} -bt cubic"
    },
    "3": {
        "in": 3,
        "out": 4,
        "weight": 1,
        "cmd": "{GMX} solvate -cp {box_gro} -cs {WATERBOXFILE} -o {sol_gro} -p {sol_top}"
    },
    "4": {
        "in": 4,
        "out": 5,
        "weight": 1,
        "cmd": "{GMX} grompp -f {ions_mdp} -c {sol_gro} -p {sol_top} -o {ions_tpr} -maxwarn 1"
    },
    "5": {
        "in": 5,
        "out": 6,
        "weight": 1,
        "cmd": "echo SOL | {GMX} genion -s {ions_tpr} -o {ions_gro} -p {ions_top} -pname NA -nname CL -neutral"
    }
}
